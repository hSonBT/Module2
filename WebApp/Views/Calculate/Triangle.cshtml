@using WebApp.Models
@model Triangle
@* Đăng ký Tag Helper riêng cho file này (không cần _ViewImports.cshtml dùng chung) *@
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@* asp-for="A" tự sinh ra id="A" name="A" bind tới property A của Model,
   nhờ có @addTagHelper ở trên nên asp-for mới được Razor xử lý đúng. *@
<form method="post">
    <div>
        <label asp-for="A">Nhập cạnh A</label>
        <input type="number" min="0.1" step="0.1" asp-for="A">
    </div>
    <div>
        <label asp-for="B">Nhập cạnh B</label>
        <input type="number" min="0.1" step="0.1" asp-for="B">
    </div>
    <div>
        <label asp-for="C">Nhập cạnh C</label>
        <input type="number" min="0.1" step="0.1" asp-for="C">
    </div>
    
    @if (Model.Area > 0)
    {
        <p>Diện tích: @Model.Area</p>
    }
    
    <button type="submit">Tính diện tích</button>
</form>
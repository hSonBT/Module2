@model IEnumerable<Product>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success">@TempData["Msg"]</div>
}

<a class="btn btn-primary" asp-controller="Product" asp-action="Add">Add Product</a>

<table class="table table-bordered mt-2">
    <thead class="table table-dark">
    <tr>
        <th>Id</th>
        <th>Category</th>
        <th>Name</th>
        <th>Description</th>
        <th>Content</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Image</th>
        <th>Command</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ProductId</td>
            <td>@item.CategoryId</td>
            <td>@item.ProductName</td>
            <td>@item.Description</td>
            <td>@item.Content</td>
            <td>@item.Price</td>
            <td>@item.Quantity</td>
            <td>
                <img class="w-50 h-50 object-fit-cover" src="/images/@item.ImageUrl" alt=""/>

            </td>
            <td>
                <a class="btn btn-outline-primary" asp-controller="Product" asp-action="Edit"
                   asp-route-id="@item.ProductId">edit</a>
                <a class="del btn btn-outline-danger" asp-controller="Product" asp-action="Delete"
                   asp-route-id="@item.ProductId">delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts
{
    <script>
        $('.del').click(function () {
            return confirm('Are you sure you want to delete this product?');
        })
    </script>
}
